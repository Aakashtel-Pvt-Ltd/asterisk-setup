# =============================================================================
# asterisk-deploy environment file  (copy to .env and fill in)
# Reproduces the "Aakashtel" call-center PBX (Asterisk 22.10.0, source build)
# on a FRESH host. No real secrets are stored here — use placeholders.
# =============================================================================

# ---- Asterisk version (matches the source build on the reference server) ----
ASTERISK_VERSION=22.10.0

# ---- Networking / NAT (server is behind NAT) --------------------------------
PUBLIC_IP=203.0.113.10            # <CHANGE_ME> public/NAT IP (external media)
LOCAL_IP=172.16.176.6             # <CHANGE_ME> private IP of this host
LOCAL_CIDR=172.16.176.0/24        # LAN CIDR advertised as local_net
CARRIER_CIDR=10.40.55.0/24        # carrier/IMS network treated as local_net

# ---- RTP media range --------------------------------------------------------
RTP_START=10000
RTP_END=30000

# ---- SIP trunk (Nepal Telecom IMS on the reference box) ---------------------
SIP_PROVIDER_HOST=ims.ntc.net.np  # provider SIP domain (from_domain / client_uri)
SIP_PROXY=10.40.55.4:5060         # SBC / registrar / outbound proxy host:port
SIP_TRUNK_NAME=+97761597077       # PJSIP section name for the trunk
SIP_USERNAME=+97761597077@ims.ntc.net.np   # trunk auth username
SIP_SECRET=<ASK_USER>             # <ASK_USER> trunk auth password — never commit
DID_NUMBER=97761597077            # inbound DID (no leading +)
OUTBOUND_CID=+97761597077         # outbound caller ID
TRUNK_CODEC=alaw                  # carrier codec

# ---- Firewall allow-lists ---------------------------------------------------
PROVIDER_ALLOW_IPS=10.40.55.4     # space-separated carrier IPs allowed to SIP
ADMIN_ALLOW_IPS=<ASK_USER>        # space-separated admin IPs for SSH/AMI/HTTP

# ---- System -----------------------------------------------------------------
TIMEZONE=Asia/Kathmandu
SYSTEMNAME=Aakashtel

# ---- TLS / WebRTC certificates ---------------------------------------------
ENABLE_TLS=yes
TLS_CERT=/home/certs/fullchain.pem   # Asterisk reads this (copied from Let's Encrypt)
TLS_KEY=/home/certs/privkey.pem      # copied from Let's Encrypt by the cert deploy hook

# ---- HTTP / ARI -------------------------------------------------------------
ENABLE_ARI=yes
HTTP_BIND=127.0.0.1:8088          # hardened default (loopback); was 0.0.0.0:8088
HTTPS_BIND=0.0.0.0:7443           # non-standard TLS port used by the app
ARI_USER=aakashtel
ARI_SECRET=<ASK_USER>             # <ASK_USER> ARI password (stored crypted)

# ---- AMI (Asterisk Manager Interface) --------------------------------------
ENABLE_AMI=yes
AMI_BIND=127.0.0.1                # hardened default (loopback); was 0.0.0.0
AMI_USER=mark
AMI_SECRET=<ASK_USER>            # <ASK_USER> AMI password

# ---- Web front-end (nginx + PHP-FPM serving /home/projects) ----------------
ENABLE_NGINX=yes
DOMAIN=manipal.aakashtel.com      # <CHANGE_ME> public hostname (nginx + TLS cert)
WEB_ROOT=/home/projects           # nginx document root
PHP_VERSION=8.3                    # PHP-FPM version (php${PHP_VERSION}-fpm)
RECORDINGS_DIR=/home/projects/voice/records   # served at https://DOMAIN/voice/

# ---- TLS via Let's Encrypt / certbot ---------------------------------------
CERTBOT_EMAIL=<ASK_USER>          # <ASK_USER> email for Let's Encrypt registration
CERT_LIVE_DIR=/etc/letsencrypt/live/manipal.aakashtel.com   # <CHANGE_ME> follows DOMAIN
CERT_DEST=/home/certs             # where certs are copied for Asterisk (asterisk-readable)
# TLS_CERT/TLS_KEY (above) should point at CERT_DEST/fullchain.pem and privkey.pem

# ---- App layer (PHP AGI + Node AMI/broadcast) ------------------------------
PROJECTS_DIR=/home/projects
APP_BACKEND_BASE_URL=<ASK_USER>   # backend API base URL the AGI/AMI apps call
NODE_VERSION=v24.16.0
# Companion systemd services to install/enable (space-separated)
APP_SERVICES=ami broadcast sipuser sipqueue-populate
