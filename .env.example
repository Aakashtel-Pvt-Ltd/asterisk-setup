# =============================================================================
# asterisk-deploy environment file  (copy to .env and fill in)
# Reproduces the "Aakashtech" PBX (Asterisk 22.7.0 source build) on a FRESH
# host. Templates were regenerated 2026-07 from the live server's /etc/asterisk.
# No real secrets are stored here — use placeholders.
# =============================================================================

# ---- Asterisk version (matches the source build on the live server) ---------
ASTERISK_VERSION=22.7.0

# ---- Networking --------------------------------------------------------------
PUBLIC_IP=182.93.84.121           # <CHANGE_ME> public IP (external_media_address)
LOCAL_CIDR=192.168.0.0/24         # LAN CIDR advertised as local_net

# ---- RTP media range (must match the firewall rule) --------------------------
RTP_START=10000
RTP_END=20000

# ---- Ncell trunk (IP-authenticated, dual SBC) --------------------------------
ENABLE_NCELL=yes
NCELL_TRUNK_NAME=+9779801730002   # PJSIP section prefix AND the Ncell number
NCELL_FROM_USER=9801730002        # From-user sent to the SBC (no country code)
NCELL_SBC_KTM=116.68.210.56       # Kathmandu SBC
NCELL_SBC_POK=116.68.213.56       # Pokhara SBC

# ---- NTC trunk (registration-based, IMS) -------------------------------------
# Previous deployments used NTC; keep both carriers supported. When enabled,
# all NTC_* values below are required.
ENABLE_NTC=yes
NTC_TRUNK_NAME=+97761597077       # PJSIP section prefix AND the NTC number
NTC_PROVIDER_HOST=ims.ntc.net.np  # provider SIP domain (from_domain)
NTC_PROXY=10.40.55.4:5060         # SBC / registrar / outbound proxy host:port
NTC_USERNAME=+97761597077@ims.ntc.net.np   # trunk auth username
NTC_SECRET=<ASK_USER>             # <ASK_USER> trunk auth password — never commit
NTC_CODEC=alaw

# ---- Local SIP peers ----------------------------------------------------------
OPENSIPS_HOST=192.168.0.154       # OpenSIPS LAN peer (kamailio/freeswitch are on
                                  # localhost and not parameterized)

# ---- Firewall allow-lists -----------------------------------------------------
PROVIDER_ALLOW_IPS="116.68.210.56 116.68.213.56 10.40.55.4"
ADMIN_ALLOW_IPS=<ASK_USER>        # space-separated admin IPs for SSH/AMI/HTTP

# ---- System -------------------------------------------------------------------
TIMEZONE=Asia/Kathmandu
SYSTEMNAME=Aakashtech             # asterisk.conf systemname (uniqueid prefix)

# ---- TLS certificates read by Asterisk -----------------------------------------
# Copied from Let's Encrypt by the cert deploy hook ('make tls').
TLS_CERT=/home/stage/asterisk/certs/fullchain.pem
TLS_KEY=/home/stage/asterisk/certs/privkey.pem

# ---- Asterisk HTTP / ARI / AMI --------------------------------------------------
HTTP_BIND=0.0.0.0                 # built-in HTTP (ARI + WS) — port defaults to 8088
HTTPS_BIND=0.0.0.0:7443           # TLS/WSS on non-standard 7443 (not 8089)
ARI_USER=username                 # live server's ARI username (apps expect it)
ARI_SECRET=<ASK_USER>             # <ASK_USER> ARI password (stored plaintext, as live)
AMI_BIND=0.0.0.0                  # AMI bind address (firewall restricts access)
AMI_USER=stage-ami
AMI_SECRET=<ASK_USER>             # <ASK_USER> AMI password

# ---- AI media gateway (websocket_client.conf) -----------------------------------
AI_GATEWAY_WS_URL=wss://gateway.aakashpay.com/realtime/

# ---- Web front-end (nginx + PHP-FPM) ---------------------------------------------
ENABLE_NGINX=yes
DOMAIN=asterisk.aakashpay.com     # <CHANGE_ME> public hostname (nginx + TLS cert)
WEB_ROOT=/home/stage/asterisk     # nginx document root (live serves the app dir)
PHP_VERSION=8.3                   # PHP-FPM version (php${PHP_VERSION}-fpm)
RECORDINGS_DIR=/home/stage/asterisk/voice/records

# ---- TLS via Let's Encrypt / certbot ----------------------------------------------
CERTBOT_EMAIL=<ASK_USER>          # <ASK_USER> email for Let's Encrypt registration
CERT_LIVE_DIR=/etc/letsencrypt/live/asterisk.aakashpay.com   # <CHANGE_ME> follows DOMAIN
CERT_DEST=/home/stage/asterisk/certs   # where certs are copied for Asterisk
# TLS_CERT/TLS_KEY (above) must point at CERT_DEST/fullchain.pem and privkey.pem

# ---- App layer (PHP AGI + Node apps) -----------------------------------------------
PROJECTS_DIR=/home/stage/asterisk # app dir: agi/, ami/, broadcast/, service/, voice/
APP_BACKEND_BASE_URL=<ASK_USER>   # backend API base URL the AGI/AMI apps call
NODE_VERSION=v22.21.0
# Companion systemd services to install/enable (space-separated).
# Live box runs only these two as systemd oneshots; the long-running Node apps
# (AMI-Broadcaster, ari-node, conference-app, ...) run under pm2 instead.
APP_SERVICES="sipuser sipqueue-populate"
